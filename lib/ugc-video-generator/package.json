{
  "name": "ugc-video-generator",
  "version": "1.0.0",
  "description": "Gerador automático de vídeos UGC para Mercado Livre",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ugc-video": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "tsx src/test-pipeline.ts",
    "test:pipeline": "tsx src/test-pipeline.ts",
    "cli": "tsx src/cli.ts",
    "generate": "tsx src/cli.ts generate",
    "setup:tts": "pip3 install edge-tts",
    "check:deps": "which ffmpeg && which edge-tts && echo 'All dependencies OK'"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fluent-ffmpeg": "^2.1.3",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.2.15",
    "marked": "^12.0.1",
    "music-metadata": "^7.14.0",
    "ora": "^8.0.1",
    "sharp": "^0.33.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.24",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "systemDependencies": {
    "edge-tts": "Python package - install with: pip3 install edge-tts",
    "ffmpeg": "System package - install with: apt install ffmpeg"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
