# ===========================================
# UGC Video Generator - Configurações
# ===========================================

# TTS Provider: 'edge' (grátis) ou 'elevenlabs' (premium)
TTS_PROVIDER=edge

# ElevenLabs (opcional - se usar provider elevenlabs)
ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Edge TTS - Voz padrão (grátis)
EDGE_TTS_VOICE=pt-BR-FranciscaNeural

# Diretórios
INPUT_DIR=./input
OUTPUT_DIR=./output
TEMP_DIR=./temp

# Configurações de vídeo
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_FORMAT=mp4
