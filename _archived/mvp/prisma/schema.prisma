generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum ProjectType {
  pptx
  template
  custom

  @@map("project_type")
}

enum ProjectStatus {
  draft
  in_progress
  review
  completed
  archived
  error

  @@map("project_status")
}

enum CollaborationRole {
  owner
  editor
  viewer
  reviewer

  @@map("collaboration_role")
}

enum RenderStatus {
  pending
  queued
  processing
  completed
  failed
  cancelled

  @@map("render_status")
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  name      String?  @db.VarChar(255)
  avatarUrl String?  @map("avatar_url") @db.Text
  role      String   @default("user") @db.VarChar(50)
  planTier  String   @default("free") @map("plan_tier") @db.VarChar(50)
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  projects        Project[]
  collaborations  ProjectCollaborator[]
  renderJobs      RenderJob[]
  analyticsEvents AnalyticsEvent[]
  notifications   Notification[]
  userRoles       UserRole[]
  usage           UserUsage[]

  @@map("users")
}

model Project {
  id                    String        @id @default(uuid()) @db.Uuid
  name                  String        @db.VarChar(255)
  description           String?       @db.Text
  type                  ProjectType   @default(pptx)
  status                ProjectStatus @default(draft)
  userId                String        @map("user_id") @db.Uuid
  metadata              Json?         @default("{}")
  thumbnailUrl          String?       @map("thumbnail_url") @db.Text
  currentVersion        Int           @default(1) @map("current_version")
  isTemplate            Boolean       @default(false) @map("is_template")
  isPublic              Boolean       @default(false) @map("is_public")
  collaborationEnabled  Boolean       @default(false) @map("collaboration_enabled")
  renderSettings        Json?         @default("{}") @map("render_settings")
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  collaborators ProjectCollaborator[]
  versions      ProjectVersion[]
  comments      ProjectComment[]
  history       ProjectHistory[]
  slides        Slide[]
  renderJobs    RenderJob[]
  analytics     ProjectAnalytics[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("projects")
}

model ProjectCollaborator {
  id          String            @id @default(uuid()) @db.Uuid
  projectId   String            @map("project_id") @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  role        CollaborationRole @default(viewer)
  permissions Json?             @default("{}")
  invitedAt   DateTime          @default(now()) @map("invited_at") @db.Timestamptz(6)
  acceptedAt  DateTime?         @map("accepted_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_collaborators")
}

model ProjectVersion {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  versionNumber  Int      @map("version_number")
  name           String?  @db.VarChar(255)
  changesSummary String?  @map("changes_summary") @db.Text
  snapshotData   Json?    @map("snapshot_data")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNumber])
  @@map("project_versions")
}

model ProjectComment {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String   @db.Text
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_comments")
}

model ProjectHistory {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  changes   Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_history")
}

model Slide {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  orderIndex   Int      @map("order_index")
  title        String?  @db.VarChar(500)
  content      Json?    @default("{}")
  notes        String?  @db.Text
  duration     Float?   @default(5)
  thumbnailUrl String?  @map("thumbnail_url") @db.Text
  hasAudio     Boolean  @default(false) @map("has_audio")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, orderIndex])
  @@map("slides")
}

model RenderJob {
  id          String       @id @default(uuid()) @db.Uuid
  projectId   String       @map("project_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  status      RenderStatus @default(pending)
  progress    Float        @default(0)
  outputUrl   String?      @map("output_url") @db.Text
  errorMsg    String?      @map("error_msg") @db.Text
  priority    Int          @default(0)
  config      Json?        @default("{}")
  startedAt   DateTime?    @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?    @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("render_jobs")
}

// ============================================
// ANALYTICS
// ============================================

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  eventType String   @map("event_type") @db.VarChar(100)
  eventData Json?    @default("{}") @map("event_data")
  sessionId String?  @map("session_id") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}

model ProjectAnalytics {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  eventType String   @map("event_type") @db.VarChar(100)
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_analytics")
}

// ============================================
// RBAC
// ============================================

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id       String @id @default(uuid()) @db.Uuid
  name     String @unique @db.VarChar(100)
  resource String @db.VarChar(100)
  action   String @db.VarChar(50)

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy String?  @map("assigned_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ============================================
// USAGE / QUOTAS
// ============================================

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50) // render_complete, collaborator_added, system
  title     String   @db.VarChar(255)
  message   String   @db.Text
  read      Boolean  @default(false)
  data      Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model UserUsage {
  id               String @id @default(uuid()) @db.Uuid
  userId           String @map("user_id") @db.Uuid
  month            String @db.VarChar(7) // "2026-02"
  rendersCount     Int    @default(0) @map("renders_count")
  storageUsedBytes BigInt @default(0) @map("storage_used_bytes")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@map("user_usage")
}
