import { buildImageUrl, buildSrcSet, buildResponsiveAttrs, generateBlurPlaceholder, computeSizes, isOverBudget, estimateFormatSavings, suggestFormat, DEFAULT_WIDTHS, QUALITY_PRESETS, SIZE_BUDGETS } from '@/lib/performance/image-optimization';

