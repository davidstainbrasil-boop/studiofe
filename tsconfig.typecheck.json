{
  "extends": "./estudio_ia_videos/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./estudio_ia_videos",
    "paths": {
      "@/*": ["./src/*"],
      "@lib/*": ["./src/lib/*"],
      "@components/*": ["./src/components/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@/types/*": ["./src/types/*"]
    }
  },
  "include": [
    "estudio_ia_videos/next-env.d.ts",
    "estudio_ia_videos/src/app/api/v1/video-jobs/**/*.ts"
  ],
  "exclude": [
