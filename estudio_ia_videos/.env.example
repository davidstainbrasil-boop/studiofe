# API Rate Limiting
API_RATE_LIMIT_FREE=10
API_RATE_LIMIT_STARTER=30
API_RATE_LIMIT_PRO=100
API_RATE_LIMIT_ENTERPRISE=1000

# Webhook Configuration
WEBHOOK_SECRET="generate-webhook-secret-with-openssl-rand-base64-32"

# FFmpeg Configuration
FFMPEG_PATH="/usr/bin/ffmpeg"
FFPROBE_PATH="/usr/bin/ffprobe"

# =============================================================================
# REALISTIC AVATAR (Talking Head) PROVIDERS
# =============================================================================

# MuseTalk - via Replicate (~$0.42/video) or fal.ai
# Uses REPLICATE_API_TOKEN above, or:
FAL_API_KEY="your-fal-ai-api-key"

# MuseTalk Local Docker (free, requires GPU)
# MUSETALK_LOCAL_ENDPOINT="http://localhost:7866"

# SadTalker Local Gradio (free, requires GPU)
# SADTALKER_LOCAL_ENDPOINT="http://localhost:7860"

# Avatar Pipeline Timeouts (optional, milliseconds)
