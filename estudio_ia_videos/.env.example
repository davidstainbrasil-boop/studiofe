# CRITICAL SECURITY - REPLACE ALL VALUES BELOW
# These are production credentials that were exposed - DO NOT USE

# Database Configuration - REPLACE WITH YOUR OWN
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.supabase.co:5432/postgres"
DIRECT_DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.supabase.co:5432/postgres"

# Supabase Configuration - REPLACE WITH YOUR PROJECT
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Authentication Secrets - GENERATE NEW ONES
JWT_SECRET="generate-new-jwt-secret-with-openssl-rand-base64-32"
JWT_EXPIRES_IN="1h"
REFRESH_TOKEN_EXPIRES_IN="7d"
TOTP_ENCRYPTION_KEY="generate-new-32-character-encryption-key"

# NextAuth Configuration
NEXTAUTH_URL="https://yourdomain.com"
NEXTAUTH_SECRET="generate-new-nextauth-secret-with-openssl-rand-base64-32"

# Supabase JWT
SUPABASE_JWT_SECRET="generate-new-supabase-jwt-secret"

# TTS APIs - REPLACE WITH YOUR KEYS
ELEVENLABS_API_KEY="sk-your-elevenlabs-api-key-here"
AZURE_TTS_KEY="your-azure-tts-key-here"
AZURE_TTS_REGION="brazilsouth"

# Email Service - REPLACE WITH YOUR OWN
RESEND_API_KEY="re_your-resend-api-key-here"
EMAIL_FROM="Estudio IA <onboarding@yourdomain.com>"

# Redis Configuration
REDIS_URL="redis://0.0.0.0:6379"
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379

# Development Settings
MOCK_STORAGE=true

# Sentry Monitoring - CONFIGURE FOR PRODUCTION
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DISABLED=true
NEXT_PUBLIC_SENTRY_DISABLED=true
NEXT_PUBLIC_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_PROFILES_SAMPLE_RATE="0.1"

# Additional Services from original file
OPENAI_API_KEY="sk-your-openai-key-here"
ENHANCEMENT_API_URL="https://your-esrgan-service.com"
ENHANCEMENT_API_KEY="your-api-key-here"
REPLICATE_API_KEY="your-replicate-api-key-here"
