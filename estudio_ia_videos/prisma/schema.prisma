generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
  schemas   = ["public", "auth"]
}

model analytics_events {
  id            String   @id
  userId        String?  @map("user_id")
  eventType     String   @map("event_type")
  eventCategory String?  @map("event_category")
  eventData     Json?    @default("{}") @map("event_data")
  resourceType  String?  @map("resource_type")
  resourceId    String?  @map("resource_id")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  sessionId     String?  @map("session_id")
  createdAt     DateTime @default(now()) @map("created_at")
  users         users?   @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([eventType, eventCategory])
  @@index([eventType])
  @@index([resourceType, resourceId])
  @@index([userId])
  @@schema("public")
}

model api_keys {
  id          String    @id
  userId      String    @map("user_id")
  name        String
  keyHash     String    @unique @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  permissions Json      @default("[\"read\"]")
  rateLimit   Int       @default(1000) @map("rate_limit")
  isActive    Boolean   @default(true) @map("is_active")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  users       users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive, expiresAt])
  @@index([keyPrefix])
  @@index([userId])
  @@schema("public")
}

model audit_logs {
  id           String   @id
  userId       String?  @map("user_id")
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  oldValues    Json?    @map("old_values")
  newValues    Json?    @map("new_values")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  users        users?   @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([createdAt])
  @@index([resourceType, resourceId])
  @@index([userId])
  @@schema("public")
}

model avatar_models {
  id                   String         @id
  name                 String
  displayName          String?        @map("display_name")
  description          String?
  category             String?
  gender               String?
  quality              String?
  thumbnailUrl         String?        @map("thumbnail_url")
  modelUrl             String?        @map("model_url")
  previewVideoUrl      String?        @map("preview_video_url")
  isActive             Boolean        @default(true) @map("is_active")
  audio2faceCompatible Boolean        @default(false) @map("audio2face_compatible")
  realTimeLipsync      Boolean        @default(false) @map("real_time_lipsync")
  rayTracingSupport    Boolean        @default(false) @map("ray_tracing_support")
  lipsyncAccuracy      Int?           @default(90) @map("lipsync_accuracy")
  modelFilePath        String?        @map("model_file_path")
  textureFiles         Json?          @map("texture_files")
  rigFilePath          String?        @map("rig_file_path")
  animationSets        Json?          @map("animation_sets")
  blendShapesFile      String?        @map("blend_shapes_file")
  supportedLanguages   String[]       @map("supported_languages")
  usageCount           Int            @default(0) @map("usage_count")
  rating               Float?         @default(5.0)
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @default(now()) @map("updated_at")
  avatar_stats         avatar_stats[]
  render_jobs          render_jobs[]
  @@schema("public")
}

model avatar_stats {
  id            String        @id
  avatarModelId String        @map("avatar_model_id")
  totalRenders  Int           @default(0) @map("total_renders")
  avgRenderTime Int?          @map("avg_render_time")
  lastUsedAt    DateTime      @default(now()) @map("last_used_at")
  avatar_models avatar_models @relation(fields: [avatarModelId], references: [id], onDelete: Cascade)
  @@schema("public")
}

model certificates {
  id                    String                 @id
  projectId             String                 @map("project_id")
  userId                String                 @map("user_id")
  nrRecordId            String?                @map("nr_record_id")
  studentName           String                 @map("student_name")
  courseName            String                 @map("course_name")
  code                  String                 @unique
  issuedAt              DateTime               @default(now()) @map("issued_at")
  validUntil            DateTime?              @map("valid_until")
  certificateUrl        String?                @map("certificate_url")
  metadata              Json?                  @default("{}")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @default(now()) @map("updated_at")
  nr_compliance_records nr_compliance_records? @relation(fields: [nrRecordId], references: [id])
  projects              projects               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users                 users                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([projectId])
  @@index([userId])
  @@schema("public")
}

model collaborators {
  id                                    String            @id
  projectId                             String            @map("project_id")
  userId                                String            @map("user_id")
  role                                  CollaborationRole @default(viewer)
  invitedBy                             String?           @map("invited_by")
  acceptedAt                            DateTime?         @map("accepted_at")
  createdAt                             DateTime          @default(now()) @map("created_at")
  users_collaborators_invited_byTousers users?            @relation("collaborators_invited_byTousers", fields: [invitedBy], references: [id])
  projects                              projects          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users_collaborators_user_idTousers    users             @relation("collaborators_user_idTousers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@schema("public")
}

model courses {
  id           String   @id
  title        String
  description  String?
  thumbnailUrl String?  @map("thumbnail_url")
  authorId     String?  @map("author_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")
  users        users?   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  videos       videos[]

  @@index([authorId])
  @@schema("public")
}

model generated_videos {
  id           String   @id
  projectId    String   @map("project_id")
  projectName  String   @map("project_name")
  videoUrl     String   @map("video_url")
  thumbnailUrl String?  @map("thumbnail_url")
  duration     Int      @default(0)
  slideCount   Int      @default(0) @map("slide_count")
  fileSize     Int?     @map("file_size")
  status       String   @default("completed")
  metadata     Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")
  @@schema("public")
}

model notifications {
  id        String    @id
  userId    String    @map("user_id")
  type      String
  title     String
  message   String?
  data      Json?     @default("{}")
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  users     users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@index([userId, isRead])
  @@schema("public")
}

model nr_compliance_records {
  id                String         @id
  projectId         String         @map("project_id")
  nr                String
  nrName            String         @map("nr_name")
  status            String
  score             Float
  finalScore        Float          @map("final_score")
  requirementsMet   Int            @map("requirements_met")
  requirementsTotal Int            @map("requirements_total")
  validatedAt       DateTime       @default(now()) @map("validated_at")
  validatedBy       String         @map("validated_by")
  recommendations   Json?
  criticalPoints    Json?          @map("critical_points")
  aiAnalysis        Json?          @map("ai_analysis")
  aiScore           Float?         @map("ai_score")
  confidence        Float?
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @default(now()) @map("updated_at")
  certificates      certificates[]
  projects          projects       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@schema("public")
}

model nr_courses {
  id              String          @id
  code            String          @unique
  name            String
  description     String?
  category        String?
  durationMinutes Int?            @map("duration_minutes")
  difficultyLevel String          @default("intermediate") @map("difficulty_level")
  thumbnailUrl    String?         @map("thumbnail_url")
  isActive        Boolean         @default(true) @map("is_active")
  metadata        Json?           @default("{}")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @map("updated_at")
  courseCode      String?         @unique @map("course_code")
  title           String?
  modulesCount    Int?            @default(0) @map("modules_count")
  status          String?         @default("active")
  duration        Int?
  nr_modules      nr_modules[]
  user_progress   user_progress[]

  @@index([code])
  @@index([isActive])
  @@schema("public")
}

model nr_modules {
  id              String          @id
  courseId        String          @map("course_id")
  moduleOrder     Int             @map("module_order")
  title           String
  description     String?
  content         Json?           @default("{}")
  videoUrl        String?         @map("video_url")
  durationMinutes Int?            @map("duration_minutes")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @map("updated_at")
  orderIndex      Int?            @map("order_index")
  thumbnailUrl    String?         @map("thumbnail_url")
  duration        Int?
  nr_courses      nr_courses      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user_progress   user_progress[]

  @@unique([courseId, moduleOrder])
  @@index([courseId])
  @@schema("public")
}

model nr_templates {
  id              String   @id
  nrNumber        String   @unique @map("nr_number")
  title           String
  description     String?
  slideCount      Int      @default(5) @map("slide_count")
  durationSeconds Int      @default(300) @map("duration_seconds")
  templateConfig  Json?    @default("{}") @map("template_config")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")
  @@schema("public")
}

model processing_queue {
  id           String   @id
  jobType      String   @map("job_type")
  jobData      Json     @map("job_data")
  status       String   @default("pending")
  priority     Int      @default(0)
  scheduledFor DateTime @default(now()) @map("scheduled_for")
  progress     Int      @default(0)
  currentStep  String?  @map("current_step")
  maxAttempts  Int      @default(3)
  attempts     Int      @default(0)
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  @@index([jobType])
  @@index([priority])
  @@index([scheduledFor])
  @@index([status])
  @@schema("public")
}

model project_comments {
  id                     String             @id
  projectId              String             @map("project_id")
  userId                 String             @map("user_id")
  content                String
  position               Json?
  parentId               String?            @map("parent_id")
  resolved               Boolean            @default(false)
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @default(now()) @map("updated_at")
  project_comments       project_comments?  @relation("project_commentsToproject_comments", fields: [parentId], references: [id], onDelete: Cascade)
  other_project_comments project_comments[] @relation("project_commentsToproject_comments")
  projects               projects           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users                  users              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([projectId])
  @@index([userId])
  @@schema("public")
}

model project_versions {
  id                                       String    @id
  projectId                                String    @map("project_id")
  versionNumber                            String    @map("version_number")
  name                                     String
  description                              String?
  changesSummary                           String?   @map("changes_summary")
  createdBy                                String    @map("created_by")
  metadata                                 Json?     @default("{}")
  createdAt                                DateTime  @default(now()) @map("created_at")
  userId                                   String?   @map("user_id")
  projectData                              Json?     @default("{}") @map("project_data")
  updatedAt                                DateTime? @map("updated_at")
  users_project_versions_created_byTousers users     @relation("project_versions_created_byTousers", fields: [createdBy], references: [id], onDelete: Cascade)
  projects                                 projects  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users_project_versions_user_idTousers    users?    @relation("project_versions_user_idTousers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNumber])
  @@index([createdBy])
  @@index([projectId])
  @@schema("public")
}

model projects {
  id                    String                  @id
  userId                String                  @map("user_id")
  name                  String
  type                  ProjectType             @default(custom)
  status                ProjectStatus           @default(draft)
  description           String?
  metadata              Json?                   @default("{}")
  currentVersion        String                  @default("1.0.0") @map("current_version")
  isTemplate            Boolean                 @default(false) @map("is_template")
  isPublic              Boolean                 @default(false) @map("is_public")
  collaborationEnabled  Boolean                 @default(false) @map("collaboration_enabled")
  renderSettings        Json?                   @default("{}") @map("render_settings")
  thumbnailUrl          String?                 @map("thumbnail_url")
  previewUrl            String?                 @map("preview_url")
  lastAccessedAt        DateTime                @default(now()) @map("last_accessed_at")
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @default(now()) @map("updated_at")
  slidesData            Json?                   @map("slides_data")
  totalSlides           Int?                    @default(0) @map("total_slides")
  duration              Int?                    @default(0)
  autoNarration         Boolean?                @default(false) @map("auto_narration")
  pptxUrl               String?                 @map("pptx_url")
  originalFileName      String?                 @map("original_file_name")
  processingLog         Json?                   @map("processing_log")
  certificates          certificates[]
  collaborators         collaborators[]
  nr_compliance_records nr_compliance_records[]
  project_comments      project_comments[]
  project_versions      project_versions[]
  users                 users                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  render_jobs           render_jobs[]
  slides                slides[]
  timeline_presence     timeline_presence[]
  timeline_track_locks  timeline_track_locks[]
  timelines             timelines?
  tts_jobs              tts_jobs[]
  video_exports         video_exports[]
  video_projects        video_projects[]

  @@index([isPublic])
  @@index([status])
  @@index([type])
  @@index([userId])
  @@schema("public")
}

model render_jobs {
  id                String          @id
  videoProjectId    String?         @map("video_project_id")
  projectId         String?         @map("project_id")
  userId            String          @map("user_id")
  status            JobStatus       @default(pending)
  priority          PriorityLevel   @default(medium)
  quality           video_quality   @default(p1080)
  progress          Int             @default(0)
  settings          Json?           @default("{}")
  outputUrl         String?         @map("output_url")
  errorMessage      String?         @map("error_message")
  startedAt         DateTime?       @map("started_at")
  completedAt       DateTime?       @map("completed_at")
  estimatedDuration Int?            @map("estimated_duration")
  actualDuration    Int?            @map("actual_duration")
  workerId          String?         @map("worker_id")
  retryCount        Int             @default(0) @map("retry_count")
  maxRetries        Int             @default(3) @map("max_retries")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @default(now()) @map("updated_at")
  renderSettings    Json?           @default("{}") @map("render_settings")
  attempts          Int?            @default(1)
  durationMs        Int?            @map("duration_ms")
  thumbnailUrl      String?         @map("thumbnail_url")
  avatarModelId     String?         @map("avatar_model_id")
  idempotencyKey    String?         @unique @map("idempotency_key")
  avatar_models     avatar_models?  @relation(fields: [avatarModelId], references: [id])
  projects          projects?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users             users           @relation(fields: [userId], references: [id], onDelete: Cascade)
  video_projects    video_projects? @relation(fields: [videoProjectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([status, priority, createdAt])
  @@index([userId])
  @@index([idempotencyKey])
  @@schema("public")
}




model sessions {
  id        String   @id
  userId    String   @map("user_id")
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([token])
  @@index([userId])
  @@schema("public")
}

model slides {
  id                 String     @id
  projectId          String     @map("project_id")
  slideOrder         Int        @default(0) @map("slide_order")
  orderIndex         Int        @default(0) @map("order_index")
  title              String?
  content            Json?      @default("{}")
  layoutType         String     @default("blank") @map("layout_type")
  background         Json?      @default("{\"type\": \"color\", \"value\": \"#ffffff\"}")
  notes              String?
  durationSeconds    Int        @default(5) @map("duration_seconds")
  transitionType     String     @default("none") @map("transition_type")
  transitionDuration Int        @default(500) @map("transition_duration")
  audioUrl           String?    @map("audio_url")
  audioScript        String?    @map("audio_script")
  ttsSettings        Json?      @default("{}") @map("tts_settings")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @default(now()) @map("updated_at")
  backgroundColor    String?    @map("background_color")
  backgroundImage    String?    @map("background_image")
  avatarConfig       Json?      @default("{}") @map("avatar_config")
  audioConfig        Json?      @default("{}") @map("audio_config")
  duration           Int?       @default(5)
  projects           projects   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tts_jobs           tts_jobs[]

  @@index([projectId])
  @@index([projectId, slideOrder])
  @@schema("public")
}

model storage_files {
  id            String   @id
  userId        String   @map("user_id")
  bucket        String   @default("uploads")
  filePath      String   @map("file_path")
  originalName  String   @map("original_name")
  mimeType      String?  @map("mime_type")
  fileSize      BigInt?  @map("file_size")
  checksum      String?
  metadata      Json?    @default("{}")
  isPublic      Boolean  @default(false) @map("is_public")
  downloadCount Int      @default(0) @map("download_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")
  users         users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bucket, filePath])
  @@index([bucket])
  @@index([isPublic])
  @@index([userId])
  @@schema("public")
}

model system_settings {
  id        String   @id
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  @@schema("public")
}

model templates {
  id           String   @id
  name         String
  description  String?
  category     String   @default("general")
  thumbnailUrl String?  @map("thumbnail_url")
  previewUrl   String?  @map("preview_url")
  templateData Json     @map("template_data")
  isPremium    Boolean  @default(false) @map("is_premium")
  isPublic     Boolean  @default(true) @map("is_public")
  usageCount   Int      @default(0) @map("usage_count")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")
  users        users?   @relation(fields: [createdBy], references: [id])

  @@index([category])
  @@index([createdBy])
  @@index([isPublic])
  @@schema("public")
}

model timeline_presence {
  id             String   @id
  projectId      String   @map("project_id")
  userId         String   @map("user_id")
  currentTrackId String?  @map("current_track_id")
  lastSeenAt     DateTime @default(now()) @map("last_seen_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")
  projects       projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users          users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@schema("public")
}

model timeline_snapshots {
  id            String    @id
  timelineId    String    @map("timeline_id")
  version       Int
  tracks        Json?     @default("[]")
  settings      Json?     @default("{}")
  totalDuration Int?      @default(0) @map("total_duration")
  description   String?
  createdBy     String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  users         users?    @relation(fields: [createdBy], references: [id])
  timelines     timelines @relation(fields: [timelineId], references: [id], onDelete: Cascade)

  @@index([timelineId])
  @@schema("public")
}

model timeline_templates {
  id            String   @id
  name          String
  description   String?
  category      String   @default("custom")
  isPublic      Boolean  @default(false) @map("is_public")
  tracks        Json?    @default("[]")
  settings      Json?    @default("{}")
  totalDuration Int?     @default(0) @map("total_duration")
  metadata      Json?    @default("{}")
  usageCount    Int      @default(0) @map("usage_count")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")
  users         users    @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([createdBy])
  @@index([isPublic])
  @@schema("public")
}

model timeline_track_locks {
  id        String   @id
  projectId String   @map("project_id")
  trackId   String   @map("track_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  projects  projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, trackId, userId])
  @@index([projectId])
  @@index([userId])
  @@schema("public")
}

model timelines {
  id                 String               @id
  projectId          String               @unique @map("project_id")
  tracks             Json?                @default("[]")
  totalDuration      Int?                 @default(0) @map("total_duration")
  version            Int                  @default(1)
  settings           Json?                @default("{}")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @default(now()) @map("updated_at")
  timeline_snapshots timeline_snapshots[]
  projects           projects             @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model tts_jobs {
  id              String      @id
  userId          String      @map("user_id")
  projectId       String?     @map("project_id")
  slideId         String?     @map("slide_id")
  textContent     String      @map("text_content")
  provider        TtsProvider @default(edge_tts)
  voiceId         String?     @map("voice_id")
  voiceSettings   Json?       @default("{}") @map("voice_settings")
  status          JobStatus   @default(pending)
  outputUrl       String?     @map("output_url")
  durationSeconds Decimal?    @map("duration_seconds") @db.Decimal(10, 2)
  errorMessage    String?     @map("error_message")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @default(now()) @map("updated_at")
  projects        projects?   @relation(fields: [projectId], references: [id])
  slides          slides?     @relation(fields: [slideId], references: [id])
  users           users       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([slideId])
  @@index([status])
  @@index([userId])
  @@schema("public")
}

model user_progress {
  id                 String      @id
  userId             String      @map("user_id")
  courseId           String?     @map("course_id")
  moduleId           String?     @map("module_id")
  progressPercent    Int         @default(0) @map("progress_percent")
  completedAt        DateTime?   @map("completed_at")
  lastAccessedAt     DateTime    @default(now()) @map("last_accessed_at")
  metadata           Json?       @default("{}")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @default(now()) @map("updated_at")
  videoId            String?     @map("video_id")
  progressPercentage Int?        @default(0) @map("progress_percentage")
  completed          Boolean?    @default(false)
  lastWatchedAt      DateTime?   @map("last_watched_at")
  nr_courses         nr_courses? @relation(fields: [courseId], references: [id], onDelete: Cascade)
  nr_modules         nr_modules? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  users              users       @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos             videos?     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, moduleId])
  @@index([courseId])
  @@index([moduleId])
  @@index([userId])
  @@schema("public")
}

model user_preferences {
  id                String   @id
  userId            String   @unique @map("user_id")
  theme             String   @default("light")
  language          String   @default("en")
  notifications     Json     @default("{\"email\": true, \"push\": true}")
  defaultQuality    String   @default("1080p") @map("default_quality")
  lastProjectId     String?  @map("last_project_id")
  showTutorials     Boolean  @default(true) @map("show_tutorials")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")
  users             users    @relation("UserPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("public")
}

model users {
  id                                                  String                 @id
  email                                               String                 @unique
  passwordHash                                        String?                @map("password_hash")
  name                                                String?
  avatarUrl                                           String?                @map("avatar_url")
  role                                                UserRole?              @default(user)
  isActive                                            Boolean                @default(true) @map("is_active")
  isVerified                                          Boolean                @default(false) @map("is_verified")
  verificationToken                                   String?                @map("verification_token")
  resetToken                                          String?                @map("reset_token")
  resetTokenExpires                                   DateTime?              @map("reset_token_expires")
  lastLogin                                           DateTime?              @map("last_login")
  loginCount                                          Int                    @default(0) @map("login_count")
  createdAt                                           DateTime               @default(now()) @map("created_at")
  updatedAt                                           DateTime               @default(now()) @map("updated_at")
  metadata                                            Json?                  @default("{}")
  analytics_events                                    analytics_events[]
  api_keys                                            api_keys[]
  audit_logs                                          audit_logs[]
  certificates                                        certificates[]
  collaborators_collaborators_invited_byTousers       collaborators[]        @relation("collaborators_invited_byTousers")
  collaborators_collaborators_user_idTousers          collaborators[]        @relation("collaborators_user_idTousers")
  courses                                             courses[]
  notifications                                       notifications[]
  project_comments                                    project_comments[]
  project_versions_project_versions_created_byTousers project_versions[]     @relation("project_versions_created_byTousers")
  project_versions_project_versions_user_idTousers    project_versions[]     @relation("project_versions_user_idTousers")
  projects                                            projects[]
  render_jobs                                         render_jobs[]
  sessions                                            sessions[]
  storage_files                                       storage_files[]
  templates                                           templates[]
  timeline_presence                                   timeline_presence[]
  timeline_snapshots                                  timeline_snapshots[]
  timeline_templates                                  timeline_templates[]
  timeline_track_locks                                timeline_track_locks[]
  tts_jobs                                            tts_jobs[]
  user_preferences                                    user_preferences?      @relation("UserPreferences")
  user_progress                                       user_progress[]
  video_exports                                       video_exports[]
  video_projects                                      video_projects[]
  subscriptions                                       subscriptions[]

  @@index([email])
  @@index([role])
  @@schema("public")
}

model video_exports {
  id            String   @id
  projectId     String   @map("project_id")
  userId        String?  @map("user_id")
  format        String   @default("mp4")
  quality       String   @default("hd")
  resolution    String?
  fps           Int      @default(30)
  status        String   @default("queued")
  progress      Int      @default(0)
  processingLog Json?    @map("processing_log")
  videoUrl      String?  @map("video_url")
  fileUrl       String?  @map("file_url")
  fileName      String?  @map("file_name")
  fileSize      BigInt?  @map("file_size")
  duration      Int?
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @map("updated_at")
  projects      projects @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users         users?   @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@schema("public")
}

model video_projects {
  id              String        @id
  projectId       String?       @map("project_id")
  userId          String        @map("user_id")
  name            String
  description     String?
  settings        Json?         @default("{}")
  timelineData    Json?         @default("{\"tracks\": [], \"duration\": 0}") @map("timeline_data")
  status          ProjectStatus @default(draft)
  outputUrl       String?       @map("output_url")
  thumbnailUrl    String?       @map("thumbnail_url")
  durationSeconds Int?          @map("duration_seconds")
  fileSizeBytes   BigInt?       @map("file_size_bytes")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @default(now()) @map("updated_at")
  render_jobs     render_jobs[]
  projects        projects?     @relation(fields: [projectId], references: [id])
  users           users         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([userId])
  @@schema("public")
}

model videos {
  id            String          @id
  title         String
  description   String?
  videoUrl      String          @map("video_url")
  thumbnailUrl  String?         @map("thumbnail_url")
  duration      Int?
  courseId      String?         @map("course_id")
  orderIndex    Int?            @default(0) @map("order_index")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @default(now()) @map("updated_at")
  user_progress user_progress[]
  courses       courses?        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@schema("public")
}

model voice_clones {
  id             String   @id
  userId         String   @map("user_id")
  name           String
  description    String?
  provider       String   @default("elevenlabs")
  voiceId        String   @map("voice_id")
  sampleCount    Int      @default(0) @map("sample_count")
  trainingStatus String?  @map("training_status")
  qualityScore   Float?   @map("quality_score")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  @@index([userId])
  @@schema("public")
}

model voice_models {
  id               String   @id
  userId           String   @map("user_id")
  name             String
  type             String   @default("custom")
  voiceId          String   @map("voice_id")
  quality          Float    @default(0.9)
  language         String   @default("pt-BR")
  gender           String   @default("neutral")
  age              String   @default("adult")
  accent           String   @default("neutral")
  sampleUrl        String?  @map("sample_url")
  sampleDuration   Int      @default(0) @map("sample_duration")
  trainingStatus   String   @default("ready") @map("training_status")
  trainingProgress Int      @default(100) @map("training_progress")
  metadata         Json?    @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  @@index([language])
  @@index([type])
  @@index([userId])
  @@schema("public")
}

model webhook_deliveries {
  id           String    @id
  webhookId    String    @map("webhook_id")
  event        String
  payload      Json
  url          String
  status       String
  scheduledFor DateTime  @default(now()) @map("scheduled_for")
  deliveredAt  DateTime? @map("delivered_at")
  responseCode Int?      @map("response_code")
  responseBody String?   @map("response_body")
  responseTime Int?      @map("response_time")
  attempts     Int       @default(0)
  error        String?
  nextRetryAt  DateTime? @map("next_retry_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @map("updated_at")
  webhooks     webhooks  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([webhookId])
  @@schema("public")
}

model webhooks {
  id                   String               @id
  userId               String               @map("user_id")
  url                  String
  secret               String
  events               Json
  active               Boolean              @default(true)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @default(now()) @map("updated_at")
  lastDeliveryAt       DateTime?            @map("last_delivery_at")
  totalDeliveries      Int                  @default(0) @map("total_deliveries")
  successfulDeliveries Int                  @default(0) @map("successful_deliveries")
  failedDeliveries     Int                  @default(0) @map("failed_deliveries")
  retryInterval        Int                  @default(60) @map("retry_interval")
  webhook_deliveries   webhook_deliveries[]

  @@index([userId])
  @@schema("public")
}

model subscriptions {
  id                   String    @id
  userId               String    @unique @map("user_id")
  planId               String    @map("plan_id")
  status               String
  startDate            DateTime  @map("start_date")
  endDate              DateTime? @map("end_date")
  trialStartDate       DateTime? @map("trial_start_date")
  trialEndDate         DateTime? @map("trial_end_date")
  cancellationReason   String?   @map("cancellation_reason")
  autoRenew            Boolean   @default(true) @map("auto_renew")
  paymentGateway       String?   @map("payment_gateway")
  paymentGatewaySubId  String?   @unique @map("payment_gateway_sub_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @map("updated_at")
  users                users     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription_plans   subscription_plans @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([status])
  @@index([userId])
  @@schema("public")
}

model subscription_plans {
  id                 String          @id
  name               String
  description        String?
  price              Float
  currency           String
  billingCycle       String          @map("billing_cycle")
  features           Json
  isActive           Boolean         @default(true) @map("is_active")
  trialDays          Int             @default(0) @map("trial_days")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @default(now()) @map("updated_at")
  stripePriceId      String?         @unique @map("stripe_price_id")
  maxVideoProjects   Int?            @map("max_video_projects")
  maxStorageGb       Int?            @map("max_storage_gb")
  maxTeamMembers     Int?            @map("max_team_members")
  supportLevel       String?         @map("support_level")
  subscriptions      subscriptions[]

  @@index([isActive])
  @@schema("public")
}

enum CollaborationRole {
  owner
  editor
  viewer
  reviewer

  @@schema("public")
}

enum JobStatus {
  pending
  processing
  completed
  failed
  cancelled

  @@schema("public")
}

enum PriorityLevel {
  low
  medium
  high
  urgent

  @@schema("public")
}

enum ProjectStatus {
  draft
  in_progress
  review
  completed
  archived
  error

  @@schema("public")
}

enum ProjectType {
  pptx
  template_nr
  talking_photo
  custom
  ai_generated

  @@schema("public")
}

enum TtsProvider {
  elevenlabs
  azure
  google
  openai
  edge_tts

  @@schema("public")
}

enum UserRole {
  admin
  manager
  editor
  viewer
  user

  @@schema("public")
}

enum video_quality {
  p720
  p1080
  p4k

  @@schema("public")
}
