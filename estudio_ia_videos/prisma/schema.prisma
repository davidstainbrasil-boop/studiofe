}

model subtitle_tracks {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transcriptionId  String         @map("transcription_id") @db.Uuid
  language         String         @db.VarChar(20)
  segments         Json           @default("[]")
  srtUrl           String?        @map("srt_url")
  vttUrl           String?        @map("vtt_url")
  createdAt        DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime?      @default(now()) @map("updated_at") @db.Timestamptz(6)
  transcriptions   transcriptions @relation(fields: [transcriptionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([transcriptionId], map: "idx_subtitle_tracks_transcription_id")
  @@schema("public")
}

model user_usage {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  month            String    @db.VarChar(7)
  rendersCount     Int       @default(0) @map("renders_count")
  storageUsedBytes BigInt    @default(0) @map("storage_used_bytes")
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  users            users     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, month], map: "idx_user_usage_user_month")
  @@schema("public")
}

model videos {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String          @db.VarChar(500)
  description   String?
  videoUrl      String          @map("video_url")
  thumbnailUrl  String?         @map("thumbnail_url")
  duration      Int?
  courseId      String?         @map("course_id") @db.Uuid
  orderIndex    Int?            @default(0) @map("order_index")
  createdAt     DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?       @default(now()) @map("updated_at") @db.Timestamptz(6)
  user_progress user_progress[]
  courses       courses?        @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([courseId], map: "idx_videos_course_id")
  @@index([orderIndex], map: "idx_videos_order_index")
  @@schema("public")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
