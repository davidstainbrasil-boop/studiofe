generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
  schemas   = ["auth", "public"]
}

model analytics_events {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  eventType String    @map("event_type") @db.VarChar(100)
  eventData Json?     @default("{}") @map("event_data")
  sessionId String?   @map("session_id") @db.VarChar(255)
  ipAddress String?   @map("ip_address") @db.VarChar(50)
  userAgent String?   @map("user_agent")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  users     users?    @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([createdAt], map: "idx_analytics_events_created_at")
  @@index([eventType], map: "idx_analytics_events_event_type")
  @@index([userId], map: "idx_analytics_user_id")
  @@schema("public")
}

model courses {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String    @db.VarChar(500)
  description  String?
  thumbnailUrl String?   @map("thumbnail_url")
  authorId     String?   @map("author_id") @db.Uuid
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  users        users?    @relation(fields: [authorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  videos       videos[]

  @@index([authorId], map: "idx_courses_author_id")
  @@schema("public")
}

model nr_courses {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseCode   String       @unique @map("course_code") @db.VarChar(10)
  title        String       @db.VarChar(500)
  description  String?
  thumbnailUrl String?      @map("thumbnail_url")
  duration     Int?
  modulesCount Int?         @default(0) @map("modules_count")
  status       String?      @default("active") @db.VarChar(50)
  metadata     Json?        @default("{}")
  createdAt    DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?    @default(now()) @map("updated_at") @db.Timestamptz(6)
  nr_modules   nr_modules[]

  @@schema("public")
}

model nr_modules {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId     String?     @map("course_id") @db.Uuid
  orderIndex   Int         @map("order_index")
  title        String      @db.VarChar(500)
  description  String?
  thumbnailUrl String?     @map("thumbnail_url")
  videoUrl     String?     @map("video_url")
  duration     Int?
  content      Json?       @default("{}")
  createdAt    DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime?   @default(now()) @map("updated_at") @db.Timestamptz(6)
  nr_courses   nr_courses? @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([courseId], map: "idx_nr_modules_course_id")
  @@index([orderIndex], map: "idx_nr_modules_order_index")
  @@schema("public")
}

model nr_templates {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nrNumber        String    @unique @map("nr_number") @db.VarChar(10)
  title           String
  description     String?
  slideCount      Int       @default(5) @map("slide_count")
  durationSeconds Int       @default(300) @map("duration_seconds")
  templateConfig  Json?     @default("{}") @map("template_config")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "idx_nr_templates_created_at")
  @@index([nrNumber], map: "idx_nr_templates_nr_number")
  @@schema("public")
}

model project_comments {
  id                     String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId              String             @map("project_id") @db.Uuid
  userId                 String             @map("user_id") @db.Uuid
  parentId               String?            @map("parent_id") @db.Uuid
  content                String
  metadata               Json?              @default("{\"position\": null, \"resolved\": false, \"element_id\": null}")
  createdAt              DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime?          @default(now()) @map("updated_at") @db.Timestamptz(6)
  project_comments       project_comments?  @relation("project_commentsToproject_comments", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_project_comments project_comments[] @relation("project_commentsToproject_comments")
  projects               projects           @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                  auth_users         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([parentId], map: "idx_project_comments_parent_id")
  @@index([projectId], map: "idx_project_comments_project_id")
  @@index([userId], map: "idx_project_comments_user_id")
  @@schema("public")
}

model project_versions {
  id                                       String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId                                String     @map("project_id") @db.Uuid
  versionNumber                            String     @map("version_number") @db.VarChar(20)
  name                                     String     @db.VarChar(255)
  description                              String?
  changesSummary                           String?    @map("changes_summary")
  createdBy                                String     @map("created_by") @db.Uuid
  metadata                                 Json?      @default("{}")
  createdAt                                DateTime?  @default(now()) @map("created_at") @db.Timestamptz(6)
  users_project_versions_created_byTousers auth_users @relation("project_versions_created_byTousers", fields: [createdBy], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects                                 projects   @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([projectId, versionNumber])
  @@index([createdAt], map: "idx_project_versions_created_at")
  @@index([projectId], map: "idx_project_versions_project_id")
  @@schema("public")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model projects {
  id                    String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                  String                  @db.VarChar(255)
  type                  project_type            @default(custom)
  status                project_status?         @default(draft)
  description           String?
  userId                String                  @map("user_id") @db.Uuid
  metadata              Json?                   @default("{\"tags\": [], \"category\": \"general\", \"priority\": \"medium\", \"custom_fields\": {}}")
  currentVersion        String?                 @default("1.0.0") @map("current_version") @db.VarChar(20)
  isTemplate            Boolean?                @default(false) @map("is_template")
  isPublic              Boolean?                @default(false) @map("is_public")
  collaborationEnabled  Boolean?                @default(false) @map("collaboration_enabled")
  renderSettings        Json?                   @default("{}") @map("render_settings")
  thumbnailUrl          String?                 @map("thumbnail_url")
  previewUrl            String?                 @map("preview_url")
  createdAt             DateTime?               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime?               @default(now()) @map("updated_at") @db.Timestamptz(6)
  lastAccessedAt        DateTime?               @default(now()) @map("last_accessed_at") @db.Timestamptz(6)
  pptx_uploads          pptx_uploads[]
  project_analytics     project_analytics[]
  project_collaborators project_collaborators[]
  project_comments      project_comments[]
  project_history       project_history[]
  project_versions      project_versions[]
  users                 auth_users              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  render_jobs           render_jobs[]
  slides                slides[]
  timelines             timelines?

  @@index([createdAt], map: "idx_projects_created_at")
  @@index([isPublic], map: "idx_projects_is_public")
  @@index([isTemplate], map: "idx_projects_is_template")
  @@index([lastAccessedAt], map: "idx_projects_last_accessed")
  @@index([status], map: "idx_projects_status")
  @@index([type], map: "idx_projects_type")
  @@index([updatedAt], map: "idx_projects_updated_at")
  @@index([userId], map: "idx_projects_user_id")
  @@index([userId, status], map: "idx_projects_user_id_status")
  @@schema("public")
}

model render_jobs {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId         String?        @map("project_id") @db.Uuid
  status            JobStatus?     @default(pending)
  progress          Int?           @default(0)
  outputUrl         String?        @map("output_url")
  errorMessage      String?        @map("error_message")
  renderSettings    Json?          @default("{}") @map("render_settings")
  attempts          Int?           @default(1)
  durationMs        Int?           @map("duration_ms")
  startedAt         DateTime?      @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?      @map("completed_at") @db.Timestamptz(6)
  createdAt         DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  userId            String?        @map("user_id") @db.Uuid
  priority          PriorityLevel? @default(medium)
  quality           video_quality? @default(p1080)
  thumbnailUrl      String?        @map("thumbnail_url")
  avatarModelId     String?        @map("avatar_model_id") @db.Uuid
  videoProjectId    String?        @map("video_project_id") @db.Uuid
  settings          Json?          @default("{}")
  estimatedDuration Int?           @map("estimated_duration")
  actualDuration    Int?           @map("actual_duration")
  workerId          String?        @map("worker_id")
  retryCount        Int?           @default(0) @map("retry_count")
  maxRetries        Int?           @default(3) @map("max_retries")
  updatedAt         DateTime?      @default(now()) @map("updated_at") @db.Timestamptz(6)
  idempotencyKey    String?        @unique @map("idempotency_key")
  projects          projects?      @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             users?         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt], map: "idx_render_jobs_created_at")
  @@index([idempotencyKey], map: "idx_render_jobs_idempotency_key")
  @@index([projectId], map: "idx_render_jobs_project_id")
  @@index([projectId, status], map: "idx_render_jobs_project_id_status")
  @@index([status], map: "idx_render_jobs_status")
  @@index([status, createdAt(sort: Desc)], map: "idx_render_jobs_status_created")
  @@index([userId, status], map: "idx_render_jobs_user_id_status")
  @@schema("public")
}

model slides {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId       String?   @map("project_id") @db.Uuid
  orderIndex      Int       @map("order_index")
  title           String?   @db.VarChar(500)
  content         String?
  duration        Int?      @default(5)
  backgroundColor String?   @map("background_color") @db.VarChar(50)
  backgroundImage String?   @map("background_image")
  avatarConfig    Json?     @default("{}") @map("avatar_config")
  audioConfig     Json?     @default("{}") @map("audio_config")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  projects        projects? @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([orderIndex], map: "idx_slides_order_index")
  @@index([projectId], map: "idx_slides_project_id")
  @@index([projectId, orderIndex], map: "idx_slides_project_id_order")
  @@schema("public")
}

model timelines {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId     String?   @unique @map("project_id") @db.Uuid
  tracks        Json?     @default("[]")
  settings      Json?     @default("{}")
  totalDuration Int?      @default(0) @map("total_duration")
  version       Int?      @default(1)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  projects      projects? @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([projectId], map: "idx_timelines_project_id")
  @@index([updatedAt(sort: Desc)], map: "idx_timelines_updated_at")
  @@schema("public")
}

model user_progress {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String?   @map("user_id") @db.Uuid
  videoId            String?   @map("video_id") @db.Uuid
  progressPercentage Int?      @default(0) @map("progress_percentage")
  completed          Boolean?  @default(false)
  lastWatchedAt      DateTime? @default(now()) @map("last_watched_at") @db.Timestamptz(6)
  createdAt          DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  users              users?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  videos             videos?   @relation(fields: [videoId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, videoId])
  @@index([completed], map: "idx_user_progress_completed")
  @@index([userId], map: "idx_user_progress_user_id")
  @@index([videoId], map: "idx_user_progress_video_id")
  @@schema("public")
}

model users {
  id               String             @id @db.Uuid
  email            String             @unique @db.VarChar(255)
  name             String?            @db.VarChar(255)
  avatarUrl        String?            @map("avatar_url")
  role             String?            @default("user") @db.VarChar(50)
  createdAt        DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime?          @default(now()) @map("updated_at") @db.Timestamptz(6)
  metadata         Json?              @default("{}")
  plan_tier        String?            @default("free") @db.VarChar(50) 
  analytics_events analytics_events[]
  courses          courses[]
  project_history  project_history[]
  render_jobs      render_jobs[]
  user_progress    user_progress[]
  user_usage       user_usage[]
  users            auth_users         @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([email], map: "idx_users_email")
  @@schema("public")
}

model user_usage {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  month             String    @db.VarChar(7) // YYYY-MM
  rendersCount      Int       @default(0) @map("renders_count")
  storageUsedBytes  BigInt    @default(0) @map("storage_used_bytes")
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  users             users     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, month], map: "idx_user_usage_user_month")
  @@schema("public")
}

model videos {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String          @db.VarChar(500)
  description   String?
  videoUrl      String          @map("video_url")
  thumbnailUrl  String?         @map("thumbnail_url")
  duration      Int?
  courseId      String?         @map("course_id") @db.Uuid
  orderIndex    Int?            @default(0) @map("order_index")
  createdAt     DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?       @default(now()) @map("updated_at") @db.Timestamptz(6)
  user_progress user_progress[]
  courses       courses?        @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([courseId], map: "idx_videos_course_id")
  @@index([orderIndex], map: "idx_videos_order_index")
  @@schema("public")
}

