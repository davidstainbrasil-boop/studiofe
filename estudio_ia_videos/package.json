  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:staging": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx src/app/scripts/seed.ts",
    "db:studio": "prisma studio",
    "queue:dev": "tsx lib/queue/video-processing.queue.ts",
    "worker": "tsx src/scripts/start-worker.ts",
    "test": "jest -c jest.config.cjs",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "docker:build": "docker build -t mvp-video-app:latest .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f app",
    "deploy:staging": "vercel",
    "deploy:prod": "vercel --prod",
    "health": "curl -f http://localhost:3000/api/health || exit 1",
    "cache:warm": "curl -X POST http://localhost:3000/api/admin/cache/warm",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs mvp-video-app",
    "pm2:monit": "pm2 monit",
    "test:performance": "./scripts/test-performance.sh",
    "test:security": "./scripts/security-audit.sh",
    "audit:full": "npm run test:security && npm run test:performance",
    "check:assets": "node check-assets.mjs https://cursostecno.com.br"
  },
  "prisma": {
    "seed": "tsx src/app/scripts/seed.ts"
  },
