{
  "version": 2,
  "buildCommand": "cd estudio_ia_videos && npm run build",
  "devCommand": "cd estudio_ia_videos && npm run dev",
  "installCommand": "cd estudio_ia_videos && npm install",
  "framework": "nextjs",
  "outputDirectory": "estudio_ia_videos/.next",
  "functions": {
    "estudio_ia_videos/src/app/api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
